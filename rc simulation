#include <stdio.h>
#include <math.h>

int main()
{
    float R, C, V, t;
    float charging_voltage, discharging_voltage;
    float tau;

    printf("Enter Resistance R (ohms): ");
    scanf("%f",&R);

    printf("Enter Capacitance C (farads): ");
    scanf("%f",&C);

    printf("Enter Supply Voltage V (volts): ");
    scanf("%f",&V);

    printf("Enter Time t (seconds): ");
    scanf("%f",&t);

    tau = R*C;

    charging_voltage = V * (1 - exp(-t/tau));
    discharging_voltage = V * exp(-t/tau);

    printf("\nTime Constant (tau) = %f seconds\n", tau);

    printf("\nCharging Voltage at time %.2f sec = %f Volts", t, charging_voltage);

    printf("\nDischarging Voltage at time %.2f sec = %f Volts", t, discharging_voltage);

    return 0;
}